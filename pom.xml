<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.mars</groupId>
    <artifactId>mars-admin</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>
    <name>QC Admin</name>
    <description>通用管理系统 - RBAC权限管理</description>

    <modules>
        <module>qc-common</module>
        <module>qc-infra</module>
        <module>qc-core</module>
        <module>qc-api</module>
        <module>qc-job</module>
        <module>qc-starter</module>
    </modules>

    <properties>
        <java.version>17</java.version>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <spring-boot.version>3.2.2</spring-boot.version>
        <mybatis-plus.version>3.5.5</mybatis-plus.version>
        <sa-token.version>1.37.0</sa-token.version>
        <hutool.version>5.8.25</hutool.version>
        <easyexcel.version>3.3.3</easyexcel.version>
        <druid.version>1.2.23</druid.version>
        <lombok.version>1.18.30</lombok.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- Spring Boot -->
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-dependencies</artifactId>
                <version>${spring-boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- MyBatis Plus -->
            <dependency>
                <groupId>com.baomidou</groupId>
                <artifactId>mybatis-plus-spring-boot3-starter</artifactId>
                <version>${mybatis-plus.version}</version>
            </dependency>

            <!-- Sa-Token -->
            <dependency>
                <groupId>cn.dev33</groupId>
                <artifactId>sa-token-spring-boot3-starter</artifactId>
                <version>${sa-token.version}</version>
            </dependency>
            <dependency>
                <groupId>cn.dev33</groupId>
                <artifactId>sa-token-redis-jackson</artifactId>
                <version>${sa-token.version}</version>
            </dependency>

            <!-- Hutool -->
            <dependency>
                <groupId>cn.hutool</groupId>
                <artifactId>hutool-all</artifactId>
                <version>${hutool.version}</version>
            </dependency>

            <!-- Lombok -->
            <dependency>
                <groupId>org.projectlombok</groupId>
                <artifactId>lombok</artifactId>
                <version>${lombok.version}</version>
            </dependency>

            <!-- EasyExcel -->
            <dependency>
                <groupId>com.alibaba</groupId>
                <artifactId>easyexcel</artifactId>
                <version>${easyexcel.version}</version>
            </dependency>

            <!-- Druid 数据库连接池 -->
            <dependency>
                <groupId>com.alibaba</groupId>
                <artifactId>druid-spring-boot-3-starter</artifactId>
                <version>${druid.version}</version>
            </dependency>

            <!-- ==================== 内部模块 ==================== -->
            <!-- 公共基础 -->
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-common</artifactId>
                <version>${project.version}</version>
            </dependency>

            <!-- 基础设施层 -->
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-db</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-redis</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-oss</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-websocket</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-sms</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-push</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-wechat</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-social</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-crypto</artifactId>
                <version>${project.version}</version>
            </dependency>

            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-mail</artifactId>
                <version>${project.version}</version>
            </dependency>

            <!-- 业务核心层 -->
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-system</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-file</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-gen</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-biz</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-message</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-pay</artifactId>
                <version>${project.version}</version>
            </dependency>

            <!-- 接口层 -->
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-admin-api</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-app-api</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-web-api</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-auth</artifactId>
                <version>${project.version}</version>
            </dependency>

            <!-- 定时任务 -->
            <dependency>
                <groupId>com.mars</groupId>
                <artifactId>qc-job</artifactId>
                <version>${project.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <encoding>UTF-8</encoding>
                    <!-- 保留方法参数名称，用于Spring MVC参数解析 -->
                    <parameters>true</parameters>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
